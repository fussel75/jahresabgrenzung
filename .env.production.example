# Produktions-Konfiguration (auf dem VPS nach .env kopieren).
# WICHTIG: .env enthält Geheimnisse und wird NICHT committet.

# Domain, unter der die App erreichbar ist (DNS-A-Record auf die VPS-IP setzen).
APP_DOMAIN=jahresabgrenzung.fristd-bau.com

# Zugangsdaten (gelten für Geschäftsführer + Steuerberater).
# Bitte ein STARKES Passwort wählen! Tipp zum Erzeugen auf dem Server:
#   openssl rand -base64 18
AUTH_USER=fristd
AUTH_PASSWORD=bitte-hier-ein-starkes-passwort-setzen

# Datenbank-Pfad wird in docker-compose.yml gesetzt (SQLite im Volume).
# Für PostgreSQL hier eine echte URL eintragen und provider im Prisma-Schema
# anpassen (siehe README -> Deployment).
# DATABASE_URL=postgresql://user:pass@host:5432/jahresabgrenzung
